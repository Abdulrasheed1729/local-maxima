---
import type { GetStaticPaths } from 'astro'
import Layout from '~/layouts/Layout.astro'
import { getSortedDevlogs } from '~/utils'
import Pagination from '~/components/Pagination.astro'
import siteConfig from '~/site.config'
import DevlogPreview from '~/components/DevlogPreview.astro'
import PageHeader from '~/components/PageHeader.astro'

// Note: Pagination like '/', '/2', '/3' only works with spread param like [...page]
export const getStaticPaths = (async ({ paginate }) => {
  const sortedLogs = await getSortedDevlogs()
  return paginate(sortedLogs.reverse(), { pageSize: siteConfig.devlogSize })
}) satisfies GetStaticPaths

const { page } = Astro.props
const pageTitle = 'Archive' + (page.currentPage > 1 ? ` - Page ${page.currentPage}` : '')
---

<Layout title={pageTitle} description="All my little Devlogs">
  <div class="mt-2 sm:mt-0">
    <PageHeader />
    {page.data.map((post) => <DevlogPreview devlog={post} />)}
    <Pagination
      prevLink={page.url.prev ? page.url.prev : undefined}
      prevText="Newer Logs"
      nextLink={page.url.next ? page.url.next : undefined}
      nextText="Older Logs"
    />
  </div>
</Layout>
